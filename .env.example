# Healing Score Agent 环境配置
# 复制此文件为 .env 并填入实际值

# 应用环境: dev | prod
APP_ENV=dev

# 服务绑定地址与端口
HOST=127.0.0.1
PORT=8000

# 数据库连接（默认 SQLite 本地文件）
DATABASE_URL=sqlite:///./data/app.db

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# LLM 提供商: ollama | deepseek | openai 等
LLM_PROVIDER=ollama

# LLM 模型名称（provider 不同则格式不同）
# - ollama 示例: qwen2.5:1.5b / llama3:8b
# - deepseek 示例: deepseek-chat
# - openai 示例: gpt-4o-mini
LLM_MODEL=qwen2.5:1.5b

# Ollama 本地服务地址
OLLAMA_BASE_URL=http://localhost:11434

# 第三方 API 密钥（DeepSeek / OpenAI 等，格式如 sk-xxxx）
API_KEY=your_api_key_here

# 第三方 API 端点地址
# - DeepSeek: https://api.deepseek.com/v1
# - OpenAI: https://api.openai.com/v1
BASE_URL=https://api.deepseek.com/v1
